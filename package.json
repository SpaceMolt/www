    "next-mdx-remote": "^6.0.0",
    "nuqs": "^2.8.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "recharts": "^3.7.0",
    "remark-gfm": "^4.0.1",
    "remark-smartypants": "^3.0.2",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
