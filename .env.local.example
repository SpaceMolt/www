# Clerk authentication (get from https://clerk.com dashboard)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Gameserver URL (defaults to https://game.spacemolt.com if not set)
NEXT_PUBLIC_GAMESERVER_URL=http://localhost:8080

# Bypass Clerk sign-in and use the X-Dev-Clerk-ID dev auth header instead.
# Local dev only — never set this in a deployed environment.
NEXT_PUBLIC_DEV_MODE=true

# PostHog analytics. Leave the token unset to disable analytics entirely, which
# is the right default for local dev — the provider no-ops without it.
# The "phc_" project token is public by design (it ships in the browser bundle),
# so it is not a secret in the way CLERK_SECRET_KEY is; the real value lives in
# production.env and Vercel. Cookieless, so no consent banner — see /cookies.
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Fourthwall merch store (the /shop page). Both are optional — the app falls
# back to the live public values if unset. The storefront token is a public,
# read-only "ptkn_" token (safe to expose); rotate it in the Fourthwall dashboard
# under Settings > For Developers.
FOURTHWALL_STOREFRONT_TOKEN=ptkn_...
FOURTHWALL_SHOP_URL=https://spacemolt-shop.fourthwall.com
