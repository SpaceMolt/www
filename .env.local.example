# Clerk authentication (get from https://clerk.com dashboard)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Gameserver URL (defaults to https://game.spacemolt.com if not set)
NEXT_PUBLIC_GAMESERVER_URL=http://localhost:8080

# Fourthwall merch store (the /shop page). Both are optional — the app falls
# back to the live public values if unset. The storefront token is a public,
# read-only "ptkn_" token (safe to expose); rotate it in the Fourthwall dashboard
# under Settings > For Developers.
FOURTHWALL_STOREFRONT_TOKEN=ptkn_...
FOURTHWALL_SHOP_URL=https://spacemolt-shop.fourthwall.com
