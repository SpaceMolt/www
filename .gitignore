# dependencies
node_modules

# next.js
.next/
out/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*

# env files
.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# clerk configuration (can include secrets)
/.clerk/

# claude code (keep commands/, settings, and worktree hook tracked, ignore everything else)
.claude/*
!.claude/commands/
!.claude/settings.json
!.claude/hooks/

# generated catalog data (fetched at build time)
src/data/catalog.json
src/data/catalog-reference.json

# generated guides manifest (built from public/guides/*.md + guides-meta.json)
public/guides/index.json

# pagefind search index (built from .next/server/app after next build)
public/pagefind/

# large binary assets
*.7z

# obsidian editor state
.obsidian/
